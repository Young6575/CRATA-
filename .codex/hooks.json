{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/validate_before_edit.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/validate_master.py"
          },
          {
            "type": "command",
            "command": "python .codex/hooks/validate_decision.py"
          }
        ]
      }
    ]
  }
}
